# ─── Clerk (Auth) ─────────────────────────────────────────────────────────
# Public key exposed to the browser through the app runtime config.
VITE_CLERK_PUBLISHABLE_KEY=
# Optional: enables networkless JWT verification (avoids calling Clerk API).
CLERK_JWT_KEY=
CLERK_SECRET_KEY=

# ─── Cloudflare Turnstile (bot protection on sign-in/sign-up) ────────────
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
