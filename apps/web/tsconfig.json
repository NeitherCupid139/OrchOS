{
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@/paraglide/messages": ["./src/paraglide/messages.js"],
      "@/paraglide/runtime": ["./src/paraglide/runtime.js"],
      "@/*": ["./src/*"]
    },
    "lib": ["ES2022", "DOM"],
    "types": ["vite/client"],

    /* Bundler mode */
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Performance */
    "skipLibCheck": true,
    "incremental": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "src/server/**/*",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
