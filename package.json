{
  "name": "orchos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter=web build",
    "dev": "bun run --filter=web dev",
    "deploy:cf": "bun run --filter=web deploy",
    "cf-typegen": "bun run --filter=web cf-typegen",
    "lint": "oxlint . --config .oxlintrc.json --ignore-path .gitignore",
    "lint:strict": "oxlint . --config .oxlintrc.json --ignore-path .gitignore --deny-warnings",
    "format": "oxfmt --write .",
    "check-types": "bun run --filter=web check-types",
    "test": "bun run --filter=web test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.0",
    "lefthook": "^1.11.13",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.7.4",
    "typescript": "6.0"
  },
  "engines": {
    "node": ">=22 <26"
  },
  "packageManager": "bun@1.3.11",
  "overrides": {
    "shiki": "^4.0.2",
    "@shikijs/transformers": "^4.0.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.0",
    "@dodopayments/tanstack": "^0.2.7",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@tanstack/react-virtual": "^3.13.25",
    "ai-gateway-provider": "3.1.3",
    "date-fns": "^4.1.0",
    "nodemailer": "^8.0.7",
    "remark-gfm": "^4.0.1",
    "unicode-animations": "^1.0.3"
  }
}
